 {
 "#####################",
 "#P ## K ###",
 "# ### ##### ### #",
 "# # # #",
 "# # ##",
 "# ### ## ###### # K#",
 "# # # ## #",
 "# ####### E # # #",
 "########## ##########",
 }, // LEVEL 2
 {
 "#####################",
 "#P # K #",
 "# ### # ### ####### #",
 "# #",
 "####### ######### # #",
 "# # # #",
 "# #### #### ##### # #",
 "# K ###",
 "##### #### #### #####",
 "# ^ # # #### #",
 "# ####### E ### #",
 "########## ##########",
 },
 // LEVEL 3
 {
 "#####################",
 "#P ^ # #",
 "# ### #### ###### # #",
