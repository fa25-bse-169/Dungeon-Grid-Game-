 clearConsole();
 cout<<setw(80)<<"************************************************"<<endl;
 cout<<setw(80)<<"* WELCOME TO DUNGEON ESCAPE *"<<endl;
 cout<<setw(80)<<"* Manahil Fatima, FA25-BSE-060 *"<<endl;
 cout<<setw(80)<<"* Mishal Shahid, FA25-BSE-169 *"<<endl;
