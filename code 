bool inBounds(int x,int y){
 return x >=0 && x<ROWS && y>=0 && y<COLS;
}
bool canMove(int x,int y){
 if(!inBounds(x,y)) return false;
 return maze[x][y] != '#';
}
void handleTile(int x, int y){
 if(!inBounds(x,y))return;
 char &tile= maze[x][y];
 if (tile=='K'){
 keys++;
 tile=' ';
 cout << "\nYou picked a KEY!\n";
 } else if (tile == '^'){
 hp--;
 tile = ' ';
 cout<<"\nOuch! Spike -1 HP\n"; } else if(tile =='E'){
 if(keys >=2){
 cout<<"\nLevel Completed! Moving to next level...\n";
 }else{
 cout<<"\nExit locked. Need 2 keys.\n";
 }
 }
}
void placeRandomTrap(){
if(currentLevel==0 && moveCount%4!=0)
 return;
if(currentLevel==1 && moveCount%3!=0)
 return;
if(currentLevel==2 && moveCount%2!=0)
 return;
 for(int attempt=0; attempt<20;attempt++){
 int x= rand()%ROWS;
 int y= rand()%COLS;
 if (maze[x][y]==' ') {
 int r=rand() % 2;
 if (r==1)maze[x][y]= '^';
 break;
 }
 } }
void saveGame() {
 ofstream saveFile("savegame.txt"); // open file for writing
 if (!saveFile) {
 cout<<"Error: Could not save game.\n";
 return;
 }
 saveFile<<currentLevel<<" "<<hp <<" "<<keys<<" "
 <<playerX<<" "<<playerY<<"\n";
 //to Save maze
 for(int i=0; i<ROWS; ++i) {
 saveFile<<maze[i]<<"\n";
 }
 saveFile.close();
 cout<<"Game saved successfully!\n";
}
bool loadGame(){
 ifstream loadFile("savegame.txt"); // open file for reading
 if(!loadFile){
 cout<<"No saved game found.\n";
 return false;
 }
 loadFile>>currentLevel>>hp>>keys>>playerX>>playerY;
 loadFile.ignore(); maze.clear();
 string row;
 while(getline(loadFile, row)){
 maze.push_back(row);
 }
 ROWS = maze.size();
 COLS = maze[0].size();
 loadFile.close();
 cout<<"Game loaded successfully!\n";
 return true;
}