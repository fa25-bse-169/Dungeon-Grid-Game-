 "# K # ## #",
 "########### ## #####",
 "# ^ # # # #",
 "# ####### E #",
 "########## ##########", }
};
vector<string> maze;
int ROWS=0, COLS=0;
int playerX=0, playerY=0;
//function prototypes
void clearConsole();
void loadLevel(int L);
void printMaze();
bool inBounds(int x,int y);
bool canMove(int x,int y);
void handleTile(int x,int y);
void placeRandomTrap();
void saveGame();
bool loadGame();
int main() {
srand(time(0));
cout<<"Do you want to load a saved game?(y for yes/n for no):"; char choice;
cin>>choice;
if(choice=='y'||choice=='Y'){
 if(!loadGame()){
 loadLevel(currentLevel);
 }
}else{
 loadLevel(currentLevel);
}
 while(true){
 if(hp <= 0){
 printMaze();
 cout << "\n You died. Game Over.\n";
 break;
 }
 printMaze();
 cout<<"\nMove (W/A/S/D) or Q to save & quit: ";
 char mv;
 cin>>mv;
 if(mv=='q'||mv =='Q'){
 saveGame();
 cout << "Exiting game.\n";
 break;
 }
 moveCount++;
// place items (may or may not place)
 placeRandomTrap(); int nx=playerX, ny=playerY;
 if(mv=='w' || mv=='W')
 nx--;
 else if(mv=='s' || mv=='S')
 nx++;
 else if(mv=='a' || mv=='A')
 ny--;
 else if(mv=='d' || mv=='D')
 ny++;
 if (!inBounds(nx, ny))
 continue;
 if (!canMove(nx, ny))
 continue;
 // if tile is exit
 if(maze[nx][ny]=='E'){
 if(keys>=2){
 // move player visually to exit (optional)
 playerX= nx;
 playerY= ny;
 // advance level
 currentLevel++;
 if(currentLevel>=(int)levels.size()){
 printMaze();
 cout<<"\n You finished all levels! You win!\n";
 break;
 } else{
 // reset keys for the next level, keep HP keys=0;
 loadLevel(currentLevel);
 continue;
 }
 } else{
 // can't enter exit without keys — do not move into it
 cout<<"\nThe door is locked.Find 2 keys.\n";
 continue;
 }
 }
 playerX= nx;
 playerY= ny;
 handleTile(playerX, playerY);
 }
 return 0;
}
void clearConsole(){
 #ifdef _WIN32
 system("cls");
 #else
 system("clear");
 #endif
}
void loadLevel(int L){
 maze=levels[L]; ROWS=maze.size();
 COLS=maze[0].size();
 for(int i=0; i<ROWS; ++i) {
 for(int j=0; j<COLS; ++j){
 if(maze[i][j]=='P'){
 playerX= i;
 playerY= j;
 maze[i][j]=' ';
 }
 }
}
}
